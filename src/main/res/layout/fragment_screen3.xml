<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_issue_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:endIconDrawable="@drawable/ic_mic"
        app:endIconMode="custom"
        app:hintEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_issue_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titre de l'incident" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_issue_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:endIconDrawable="@drawable/ic_mic"
        app:endIconMode="custom"
        app:hintEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_issue_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description" />
    </com.google.android.material.textfield.TextInputLayout>

    <RadioGroup
        android:id="@+id/group_environment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radio_environment_urban"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Urbain" />

        <RadioButton
            android:id="@+id/radio_environment_highway"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Autoroute" />

        <RadioButton
            android:id="@+id/radio_environment_rural"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rural" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_submit_issue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ENVOYER LE RAPPORT" />

</LinearLayout>
